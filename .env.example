# Optional override for the Soneium RPC endpoint.
# If unset, the SPA falls back to the public Soneium RPC.
# For production gh-pages deploys, set this in the deploy-pages workflow as a
# build-time variable. Public RPC is fine for low-cadence reads (60s poll).
VITE_SONEIUM_RPC_URL=

# Optional override for the gh-pages base path.
# Default: "/yoki-monitor/" (matches AstarNetwork/yoki-monitor gh-pages serving).
# For local "/"-rooted previews: set to "/" before `npm run dev`.
VITE_BASE_PATH=

# Optional URL to the public raw treasury-balance.jsonl (populated by the
# Phase 1.2 cron once the repo is on GitHub). Falls back gracefully when
# unset or unreachable — the page hides the 24h-inflow line.
VITE_TREASURY_BALANCE_JSONL_URL=
